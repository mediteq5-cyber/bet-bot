# Copie este arquivo para .env e preencha os valores
# NÃO suba o .env para o GitHub!

# Token do bot Telegram (obtido pelo @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do chat/grupo que vai receber as mensagens
# Para saber o seu, envie /start pro bot e acesse:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# Chave da API Anthropic (claude.ai → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Chave da football-data.org (plano gratuito disponível)
# Cadastro grátis em: https://www.football-data.org/client/register
FOOTBALL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Defina como "1" apenas para testar — dispara o envio na hora que iniciar
RUN_NOW=0
